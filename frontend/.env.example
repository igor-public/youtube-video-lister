# Frontend environment variables (Create React App reads any REACT_APP_* prefix).
# Copy to `.env.local` and edit. `.env.local` is gitignored.

# Base path for REST calls. Defaults to /api (proxied to the backend in dev via package.json).
# Set to an absolute URL when running the frontend against a remote backend.
# REACT_APP_API_BASE=/api

# Full WebSocket base URL including scheme, host, port, and /api prefix.
# If unset, defaults to `ws(s)://<current-host>:${REACT_APP_BACKEND_PORT or 5000}/api`.
# REACT_APP_WS_BASE=ws://localhost:5000/api

# Only used to build the default WS URL when REACT_APP_WS_BASE is not set.
# REACT_APP_BACKEND_PORT=5000
