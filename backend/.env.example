# Backend environment variables. Copy to `.env` at the project root (the existing
# location Python-dotenv reads) and fill in the values you need.
# `.env` and `*.env` are gitignored.

# --- HTTP / CORS ---
# Comma-separated list of origins the API will accept.
# Set to the frontend's URL(s). Example for local dev + staging:
#   CORS_ORIGINS=http://localhost:3000,https://ui.staging.example.com
CORS_ORIGINS=http://localhost:3000

# --- Filesystem paths (all optional; defaults are relative to the project root) ---
# CONFIG_FILE=backend/config/channels_config.json
# METADATA_DB=backend/config/transcript_metadata.json
# OUTPUT_DIR=channel_data
# LOG_DIR=logs
# RAG_DATA_DIR=backend/data

# --- YouTube ---
# YOUTUBE_API_KEY=your_api_key_here

# --- LLM provider (openai | anthropic | bedrock) ---
LLM_PROVIDER=bedrock
# LLM_MODEL=gpt-4-turbo-preview
# LLM_API_KEY=your_api_key_here

# --- Local LLM (Ollama) ---
# LOCAL_LLM_HOST=localhost
# LOCAL_LLM_PORT=11434

# --- AWS Bedrock ---
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
