# Server Configuration
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Application Configuration
CONFIG_FILE=backend/config/channels_config.json
OUTPUT_DIR=channel_data

# Optional: YouTube API Configuration
# YOUTUBE_API_KEY=your_api_key_here

# LLM Configuration (Optional)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_API_KEY=your_api_key_here

# Local LLM Configuration (for Ollama)
LOCAL_LLM_HOST=localhost
LOCAL_LLM_PORT=11434

# AWS Bedrock Configuration (for Claude via AWS)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
