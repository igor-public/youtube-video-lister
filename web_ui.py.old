#!/usr/bin/env python3
"""
Web-based UI for YouTube Toolkit
"""

import os
import json
import threading
from datetime import datetime
from pathlib import Path
from flask import Flask, render_template, jsonify, request
from flask_cors import CORS

from src.youtube_toolkit.monitor import ChannelMonitor

app = Flask(__name__)
CORS(app)

CONFIG_FILE = "channels_config.json"
OUTPUT_DIR = "channel_data"

# Global variable to track monitoring status
monitoring_status = {
    'running': False,
    'progress': '',
    'results': None,
    'error': None,
    'last_run': None
}


def load_config():
    """Load configuration from JSON file."""
    if not os.path.exists(CONFIG_FILE):
        return {
            'channels': [],
            'settings': {
                'default_days_back': 7,
                'default_languages': ['en'],
                'output_directory': OUTPUT_DIR
            }
        }

    with open(CONFIG_FILE, 'r') as f:
        return json.load(f)


def save_config(config):
    """Save configuration to JSON file."""
    with open(CONFIG_FILE, 'w') as f:
        json.dump(config, f, indent=2)


def get_channel_tree():
    """Get tree structure of channels and their transcripts."""
    tree = []

    try:
        config = load_config()
        output_dir = config.get('settings', {}).get('output_directory', OUTPUT_DIR)

        print(f"Loading tree from: {output_dir}")

        if not os.path.exists(output_dir):
            print(f"Output directory does not exist: {output_dir}")
            return tree

        for channel_name in sorted(os.listdir(output_dir)):
            channel_path = os.path.join(output_dir, channel_name)

            if not os.path.isdir(channel_path):
                continue

            transcripts_dir = os.path.join(channel_path, 'transcripts')

            if not os.path.exists(transcripts_dir):
                print(f"No transcripts directory for {channel_name}")
                continue

            # Get all transcripts
            transcripts = []
            for filename in sorted(os.listdir(transcripts_dir), reverse=True):
                if filename.endswith('.md'):
                    file_path = os.path.join(transcripts_dir, filename)
                    file_stat = os.stat(file_path)

                    # Parse filename: YYYY-MM-DD_Video_Title.md
                    parts = filename.split('_', 1)
                    date = parts[0] if len(parts) == 2 else 'unknown'
                    title = parts[1].replace('.md', '').replace('_', ' ') if len(parts) == 2 else filename.replace('.md', '')

                    transcripts.append({
                        'filename': filename,
                        'title': title,
                        'date': date,
                        'size': file_stat.st_size,
                        'path': file_path
                    })

            if transcripts:  # Only add channel if it has transcripts
                tree.append({
                    'channel': channel_name,
                    'transcript_count': len(transcripts),
                    'transcripts': transcripts
                })
                print(f"Added channel: {channel_name} with {len(transcripts)} transcripts")

    except Exception as e:
        print(f"Error building tree: {e}")
        import traceback
        traceback.print_exc()

    return tree


def run_monitoring_thread(channels, output_dir):
    """Run monitoring in a separate thread."""
    global monitoring_status

    try:
        monitoring_status['running'] = True
        monitoring_status['progress'] = 'Initializing...'
        monitoring_status['error'] = None

        monitor = ChannelMonitor(output_base_dir=output_dir)
        results = []

        for i, channel in enumerate(channels, 1):
            monitoring_status['progress'] = f'Processing channel {i}/{len(channels)}: {channel["url"]}'

            result = monitor.process_channel(
                channel_url=channel['url'],
                days_back=channel.get('days_back', 7),
                languages=channel.get('languages', ['en'])
            )
            results.append(result)

        monitoring_status['results'] = results
        monitoring_status['progress'] = 'Completed'
        monitoring_status['last_run'] = datetime.now().isoformat()

    except Exception as e:
        monitoring_status['error'] = str(e)
        monitoring_status['progress'] = 'Error'
        monitoring_status['last_run'] = datetime.now().isoformat()

    finally:
        monitoring_status['running'] = False


@app.route('/')
def index():
    """Render the main page."""
    return render_template('index.html')


@app.route('/api/config', methods=['GET'])
def get_config():
    """Get current configuration."""
    config = load_config()
    return jsonify(config)


@app.route('/api/config', methods=['POST'])
def update_config():
    """Update configuration."""
    try:
        config = request.json
        save_config(config)
        return jsonify({'success': True, 'message': 'Configuration saved'})
    except Exception as e:
        return jsonify({'success': False, 'error': str(e)}), 400


@app.route('/api/tree', methods=['GET'])
def get_tree():
    """Get channel tree structure."""
    tree = get_channel_tree()
    return jsonify(tree)


@app.route('/api/transcript/<path:channel>/<path:filename>', methods=['GET'])
def get_transcript(channel, filename):
    """Get transcript content."""
    try:
        from urllib.parse import unquote

        config = load_config()
        output_dir = config.get('settings', {}).get('output_directory', OUTPUT_DIR)

        # Decode URL-encoded characters
        channel = unquote(channel)
        filename = unquote(filename)

        print(f"Loading transcript - Channel: {channel}, Filename: {filename}")

        # Construct file path
        file_path = os.path.join(output_dir, channel, 'transcripts', filename)
        print(f"Full path: {file_path}")

        # Security check: ensure path is within output directory
        real_output = os.path.realpath(output_dir)
        real_file = os.path.realpath(file_path)

        if not real_file.startswith(real_output):
            print(f"Security check failed: {real_file} not under {real_output}")
            return jsonify({'error': 'Invalid path'}), 403

        if not os.path.exists(file_path):
            print(f"File not found: {file_path}")
            # List directory to see what files exist
            transcripts_dir = os.path.join(output_dir, channel, 'transcripts')
            if os.path.exists(transcripts_dir):
                print(f"Files in directory: {os.listdir(transcripts_dir)}")
            return jsonify({'error': f'Transcript not found', 'path': file_path}), 404

        with open(file_path, 'r', encoding='utf-8') as f:
            content = f.read()

        print(f"Successfully loaded transcript, {len(content)} bytes")
        return jsonify({
            'content': content,
            'filename': filename,
            'channel': channel,
            'path': file_path
        })

    except Exception as e:
        print(f"Exception loading transcript: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({'error': f'Error loading transcript: {str(e)}'}), 500


@app.route('/api/monitor/start', methods=['POST'])
def start_monitoring():
    """Start monitoring process."""
    global monitoring_status

    if monitoring_status['running']:
        return jsonify({'error': 'Monitoring already in progress'}), 400

    config = load_config()
    channels = []

    # Parse channels
    for ch in config.get('channels', []):
        if isinstance(ch, str):
            channels.append({
                'url': ch,
                'days_back': config['settings'].get('default_days_back', 7),
                'languages': config['settings'].get('default_languages', ['en'])
            })
        elif isinstance(ch, dict):
            channels.append({
                'url': ch['url'],
                'days_back': ch.get('days_back', config['settings'].get('default_days_back', 7)),
                'languages': ch.get('languages', config['settings'].get('default_languages', ['en']))
            })

    if not channels:
        return jsonify({'error': 'No channels configured'}), 400

    output_dir = config['settings'].get('output_directory', OUTPUT_DIR)

    # Start monitoring in a separate thread
    thread = threading.Thread(target=run_monitoring_thread, args=(channels, output_dir))
    thread.daemon = True
    thread.start()

    return jsonify({'success': True, 'message': 'Monitoring started'})


@app.route('/api/monitor/status', methods=['GET'])
def get_monitoring_status():
    """Get current monitoring status."""
    return jsonify(monitoring_status)


@app.route('/api/channels', methods=['POST'])
def add_channel():
    """Add a new channel."""
    try:
        data = request.json
        config = load_config()

        new_channel = {
            'url': data['url'],
            'days_back': data.get('days_back', 7),
            'languages': data.get('languages', ['en'])
        }

        # Ensure channels is a list of dicts
        if not config.get('channels'):
            config['channels'] = []

        # Convert simple format to dict format if needed
        channels = []
        for ch in config['channels']:
            if isinstance(ch, str):
                channels.append({
                    'url': ch,
                    'days_back': config['settings'].get('default_days_back', 7),
                    'languages': config['settings'].get('default_languages', ['en'])
                })
            else:
                channels.append(ch)

        channels.append(new_channel)
        config['channels'] = channels

        save_config(config)
        return jsonify({'success': True, 'message': 'Channel added'})

    except Exception as e:
        return jsonify({'success': False, 'error': str(e)}), 400


@app.route('/api/channels/<int:index>', methods=['DELETE'])
def delete_channel(index):
    """Delete a channel by index."""
    try:
        config = load_config()

        if index < 0 or index >= len(config['channels']):
            return jsonify({'error': 'Invalid channel index'}), 400

        config['channels'].pop(index)
        save_config(config)

        return jsonify({'success': True, 'message': 'Channel deleted'})

    except Exception as e:
        return jsonify({'success': False, 'error': str(e)}), 400


@app.route('/api/channels/<int:index>', methods=['PUT'])
def update_channel(index):
    """Update a channel by index."""
    try:
        data = request.json
        config = load_config()

        if index < 0 or index >= len(config['channels']):
            return jsonify({'error': 'Invalid channel index'}), 400

        config['channels'][index] = {
            'url': data['url'],
            'days_back': data.get('days_back', 7),
            'languages': data.get('languages', ['en'])
        }

        save_config(config)
        return jsonify({'success': True, 'message': 'Channel updated'})

    except Exception as e:
        return jsonify({'success': False, 'error': str(e)}), 400


@app.route('/api/stats', methods=['GET'])
def get_stats():
    """Get statistics."""
    tree = get_channel_tree()

    total_channels = len(tree)
    total_transcripts = sum(ch['transcript_count'] for ch in tree)

    # Calculate total size
    total_size = 0
    for channel in tree:
        for transcript in channel['transcripts']:
            total_size += transcript['size']

    return jsonify({
        'total_channels': total_channels,
        'total_transcripts': total_transcripts,
        'total_size_kb': round(total_size / 1024, 2),
        'total_size_mb': round(total_size / 1024 / 1024, 2)
    })


if __name__ == '__main__':
    print("Starting YouTube Toolkit Web UI...")
    print("Open http://localhost:5000 in your browser")
    app.run(debug=True, host='0.0.0.0', port=5000)
